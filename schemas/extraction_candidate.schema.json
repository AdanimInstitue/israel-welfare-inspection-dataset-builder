{
  "$defs": {
    "CropBox": {
      "additionalProperties": false,
      "description": "Pixel-space crop coordinates in the parent rendered page.",
      "properties": {
        "x": {
          "minimum": 0,
          "title": "X",
          "type": "integer"
        },
        "y": {
          "minimum": 0,
          "title": "Y",
          "type": "integer"
        },
        "width": {
          "exclusiveMinimum": 0,
          "title": "Width",
          "type": "integer"
        },
        "height": {
          "exclusiveMinimum": 0,
          "title": "Height",
          "type": "integer"
        }
      },
      "required": [
        "x",
        "y",
        "width",
        "height"
      ],
      "title": "CropBox",
      "type": "object"
    },
    "VisualLocator": {
      "additionalProperties": false,
      "description": "Visual evidence locator using the rendered artifact coordinate system.",
      "properties": {
        "rendered_artifact_id": {
          "minLength": 1,
          "title": "Rendered Artifact Id",
          "type": "string"
        },
        "coordinate_system": {
          "minLength": 1,
          "title": "Coordinate System",
          "type": "string"
        },
        "bounding_box": {
          "$ref": "#/$defs/CropBox"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "required": [
        "rendered_artifact_id",
        "coordinate_system",
        "bounding_box"
      ],
      "title": "VisualLocator",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Normalized candidate value from deterministic, LLM, OCR, or canonical input.",
  "properties": {
    "candidate_id": {
      "minLength": 1,
      "title": "Candidate Id",
      "type": "string"
    },
    "source_document_id": {
      "minLength": 1,
      "title": "Source Document Id",
      "type": "string"
    },
    "report_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Report Id"
    },
    "field_name": {
      "minLength": 1,
      "title": "Field Name",
      "type": "string"
    },
    "raw_value": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Raw Value"
    },
    "normalized_value": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "format": "date",
          "type": "string"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Normalized Value"
    },
    "page_number": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Page Number"
    },
    "raw_excerpt": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Raw Excerpt"
    },
    "visual_locator": {
      "anyOf": [
        {
          "$ref": "#/$defs/VisualLocator"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "extraction_method": {
      "pattern": "^(deterministic|llm_text|llm_multimodal|ocr|existing_canonical|reconciler_llm)$",
      "title": "Extraction Method",
      "type": "string"
    },
    "extractor_version": {
      "minLength": 1,
      "title": "Extractor Version",
      "type": "string"
    },
    "model_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Name"
    },
    "model_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Model Version"
    },
    "prompt_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prompt Id"
    },
    "prompt_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prompt Version"
    },
    "prompt_input_sha256": {
      "anyOf": [
        {
          "maxLength": 64,
          "minLength": 64,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Prompt Input Sha256"
    },
    "source_pdf_sha256": {
      "anyOf": [
        {
          "maxLength": 64,
          "minLength": 64,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Pdf Sha256"
    },
    "text_input_sha256": {
      "anyOf": [
        {
          "maxLength": 64,
          "minLength": 64,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Text Input Sha256"
    },
    "rendered_artifact_ids": {
      "items": {
        "type": "string"
      },
      "title": "Rendered Artifact Ids",
      "type": "array"
    },
    "rendered_artifact_sha256s": {
      "items": {
        "type": "string"
      },
      "title": "Rendered Artifact Sha256S",
      "type": "array"
    },
    "renderer_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Renderer Version"
    },
    "preprocessor_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Preprocessor Version"
    },
    "input_artifact_refs": {
      "items": {
        "type": "string"
      },
      "title": "Input Artifact Refs",
      "type": "array"
    },
    "confidence": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Confidence"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    }
  },
  "required": [
    "candidate_id",
    "source_document_id",
    "field_name",
    "extraction_method",
    "extractor_version"
  ],
  "title": "ExtractionCandidate",
  "type": "object"
}
