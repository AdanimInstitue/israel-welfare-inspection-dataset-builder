{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AdanimInstitue/israel-welfare-inspection-dataset-builder/schemas/inspection.schema.json",
  "title": "Inspection Finding Candidate",
  "description": "Review-only inspection finding candidate contract. Finding rows are not canonical exports or publication inputs yet.",
  "type": "object",
  "required": [
    "candidate_id",
    "source_document_id",
    "finding_text_raw",
    "evidence",
    "validation_status"
  ],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "source_document_id": { "type": "string", "minLength": 1 },
    "report_id": { "type": ["string", "null"] },
    "finding_index": { "type": ["integer", "null"], "minimum": 1 },
    "finding_type": { "type": ["string", "null"] },
    "severity": { "type": ["string", "null"] },
    "finding_text_raw": { "type": "string", "minLength": 1 },
    "finding_text_normalized": { "type": ["string", "null"] },
    "recommendation_raw": { "type": ["string", "null"] },
    "recommendation_normalized": { "type": ["string", "null"] },
    "legal_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_pdf_sha256": {
      "type": ["string", "null"],
      "minLength": 64,
      "maxLength": 64
    },
    "text_input_sha256": {
      "type": ["string", "null"],
      "minLength": 64,
      "maxLength": 64
    },
    "rendered_artifact_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "prompt_id": { "type": ["string", "null"] },
    "prompt_version": { "type": ["string", "null"] },
    "prompt_input_sha256": {
      "type": ["string", "null"],
      "minLength": 64,
      "maxLength": 64
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    },
    "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation_status": {
      "type": "string",
      "enum": ["valid", "invalid", "needs_review"]
    },
    "validation_errors": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
