{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adanim-institute.example/schemas/llm_evaluation_report.schema.json",
  "title": "LLM Evaluation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "started_at",
    "finished_at",
    "candidate_manifest_path",
    "schema_version",
    "prompt_id",
    "prompt_version",
    "expected_field_count",
    "observed_field_count",
    "covered_field_count",
    "correct_field_count",
    "missing_field_count",
    "incorrect_field_count",
    "regression_count",
    "field_results",
    "notes"
  ],
  "properties": {
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": ["string", "null"], "format": "date-time" },
    "candidate_manifest_path": { "type": "string", "minLength": 1 },
    "fixture_path": { "type": ["string", "null"] },
    "schema_version": { "type": "string", "minLength": 1 },
    "prompt_id": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "model_name": { "type": ["string", "null"] },
    "model_version": { "type": ["string", "null"] },
    "renderer_name": { "type": ["string", "null"] },
    "renderer_version": { "type": ["string", "null"] },
    "render_profile_id": { "type": ["string", "null"] },
    "render_profile_version": { "type": ["string", "null"] },
    "expected_field_count": { "type": "integer", "minimum": 0 },
    "observed_field_count": { "type": "integer", "minimum": 0 },
    "covered_field_count": { "type": "integer", "minimum": 0 },
    "correct_field_count": { "type": "integer", "minimum": 0 },
    "missing_field_count": { "type": "integer", "minimum": 0 },
    "incorrect_field_count": { "type": "integer", "minimum": 0 },
    "regression_count": { "type": "integer", "minimum": 0 },
    "field_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_document_id",
          "field_name",
          "expected_normalized_value",
          "observed_normalized_value",
          "status",
          "candidate_id"
        ],
        "properties": {
          "source_document_id": { "type": "string", "minLength": 1 },
          "field_name": { "type": "string", "minLength": 1 },
          "expected_normalized_value": {
            "type": ["string", "number", "integer", "null"]
          },
          "observed_normalized_value": {
            "type": ["string", "number", "integer", "null"]
          },
          "status": {
            "enum": ["correct", "incorrect", "missing", "not_observed"]
          },
          "candidate_id": { "type": ["string", "null"] }
        }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
