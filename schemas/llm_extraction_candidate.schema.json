{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adanim-institute.example/schemas/llm_extraction_candidate.schema.json",
  "title": "LLM Extraction Candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "source_document_id",
    "field_name",
    "extraction_method",
    "extractor_version",
    "source_pdf_sha256",
    "rendered_artifact_ids",
    "rendered_artifact_sha256s",
    "prompt_id",
    "prompt_version",
    "prompt_input_sha256",
    "field_evidence",
    "confidence",
    "warnings",
    "validation_status",
    "validation_errors",
    "created_at"
  ],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "source_document_id": { "type": "string", "minLength": 1 },
    "report_id": { "type": ["string", "null"] },
    "field_name": { "type": "string", "minLength": 1 },
    "raw_value": { "type": ["string", "null"] },
    "normalized_value": {
      "type": ["string", "number", "integer", "null"]
    },
    "extraction_method": { "enum": ["llm_text", "llm_multimodal"] },
    "extractor_version": { "type": "string", "minLength": 1 },
    "source_pdf_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "text_input_sha256": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    },
    "rendered_artifact_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rendered_artifact_sha256s": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },
    "prompt_id": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "prompt_input_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "model_name": { "type": ["string", "null"] },
    "model_version": { "type": ["string", "null"] },
    "field_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["page_number", "raw_excerpt", "visual_locator"],
      "properties": {
        "page_number": { "type": ["integer", "null"], "minimum": 1 },
        "raw_excerpt": { "type": ["string", "null"] },
        "visual_locator": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": [
            "rendered_artifact_id",
            "coordinate_system",
            "bounding_box"
          ],
          "properties": {
            "rendered_artifact_id": { "type": "string", "minLength": 1 },
            "coordinate_system": { "type": "string", "minLength": 1 },
            "bounding_box": {
              "type": "object",
              "additionalProperties": false,
              "required": ["x", "y", "width", "height"],
              "properties": {
                "x": { "type": "integer", "minimum": 0 },
                "y": { "type": "integer", "minimum": 0 },
                "width": { "type": "integer", "minimum": 1 },
                "height": { "type": "integer", "minimum": 1 }
              }
            },
            "note": { "type": ["string", "null"] }
          }
        }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "validation_status": { "enum": ["valid", "invalid", "needs_review"] },
    "validation_errors": { "type": "array", "items": { "type": "string" } },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
